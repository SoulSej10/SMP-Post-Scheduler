# Neon Postgres connection string (Project > Connection Details on neon.tech)
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# AI content generation (Gemini)
GEMINI_API_KEY=""

# Random secret used to sign session tokens - generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Base URL used to build OAuth redirect URIs - must match what you register with each platform
NEXT_PUBLIC_APP_URL="http://localhost:3060"

# Meta app (Facebook + Instagram) - developers.facebook.com/apps
# Register redirect URI: {NEXT_PUBLIC_APP_URL}/api/oauth/facebook/callback
# Products needed: Facebook Login, Instagram Graph API
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""

# LinkedIn app - linkedin.com/developers/apps
# Register redirect URI: {NEXT_PUBLIC_APP_URL}/api/oauth/linkedin/callback
# Products needed: "Sign In with LinkedIn using OpenID Connect", "Share on LinkedIn"
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
